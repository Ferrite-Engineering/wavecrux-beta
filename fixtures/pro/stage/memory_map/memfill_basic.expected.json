{
  "description": "4-word clocked memfill at 0x00/04/08/0C with values 0xDEADBEEF / 0xCAFEBABE / 0x12345678 / 0x00000000. Cursor at 100 ns covers all four writes.",
  "timescaleSecondsPerTick": 1e-9,
  "signals": {
    "clock": "top.dut.clk",
    "writeEnable": "top.dut.we",
    "readEnable": "top.dut.re",
    "addressBus": "top.dut.addr",
    "dataBus": "top.dut.data"
  },
  "config": {
    "mapBaseAddress": 0,
    "mapWordCount": 16,
    "wordSize": 4
  },
  "cursorTime": 100,
  "expectedSnapshot": {
    "totalAccessCount": 4,
    "mostRecentAccessIndex": 3,
    "mostRecentAccessTime": 70,
    "cells": {
      "0": { "value": "0xDEADBEEF", "lastWriteTime": 10, "lastReadTime": null },
      "1": { "value": "0xCAFEBABE", "lastWriteTime": 30, "lastReadTime": null },
      "2": { "value": "0x12345678", "lastWriteTime": 50, "lastReadTime": null },
      "3": { "value": "0x00000000", "lastWriteTime": 70, "lastReadTime": null }
    }
  },
  "backwardSeek": {
    "cursorTime": 40,
    "expectedSnapshot": {
      "totalAccessCount": 2,
      "mostRecentAccessIndex": 1,
      "mostRecentAccessTime": 30,
      "cells": {
        "0": { "value": "0xDEADBEEF", "lastWriteTime": 10 },
        "1": { "value": "0xCAFEBABE", "lastWriteTime": 30 }
      }
    }
  }
}
