$timescale 1ns $end
$comment
  ISO CAN-FD frames. Three frames with varying payload sizes:
  FD1: 29-bit ID=0x1234567, DLC=9 (12 bytes), BRS=true, ESI=false.
  FD2: 29-bit ID=0x0000001, DLC=8 (8 bytes), BRS=false, ESI=false.
  FD3: 29-bit ID=0x1AABBCC, DLC=11 (20 bytes), BRS=true, ESI=true.
  Bit period: 2000 ns (500 kbit/s at 1ns timescale). nominal_bit_period=2000.
  Regenerate via: dart run tool/generate_can_fixtures.dart
$end
$scope module tb $end
  $var wire 1 ! can_rx $end
$upscope $end
$enddefinitions $end
$dumpvars
1!
$end
