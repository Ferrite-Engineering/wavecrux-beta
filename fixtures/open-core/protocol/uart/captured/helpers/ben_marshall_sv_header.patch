From: WaveCrux fixture pipeline
Subject: [PATCH] ben-marshall/uart: SV-style #(parameter) module headers

The original RTL declares parameters (BIT_RATE, CLK_HZ, PAYLOAD_BITS, STOP_BITS)
in the module body but references PAYLOAD_BITS in the port list. iverilog 13.0
rejects this with: "Net <name> is not defined in this scope." Older iverilog
silently accepted the forward reference.

This patch converts uart_tx.v and uart_rx.v to SystemVerilog-style
`module X #(parameter ...) (...)` headers. impl_top.v and the testbenches need
no change (impl_top declares parameters in the body but doesn't use them in
the port list; testbenches use localparam exclusively).

Apply against ben-marshall/uart commit 5fd2db850a41b65aa34f3a31c663fc8704c7abd8:

  cd <clone>
  git apply ben_marshall_sv_header.patch
  make tx rx sys

Yields work/waves-{tx,rx,sys}.vcd which are then converted to FST via:

  for f in waves-tx waves-rx waves-sys; do
    vcd2fst -v work/${f}.vcd -f work/${f}.fst -Z -c
  done
---
diff --git a/rtl/uart_rx.v b/rtl/uart_rx.v
index 1cb2ead..12f4196 100644
--- a/rtl/uart_rx.v
+++ b/rtl/uart_rx.v
@@ -6,7 +6,12 @@
 // - UART reciever module.
 //

-module uart_rx(
+module uart_rx #(
+    parameter BIT_RATE     = 9600,
+    parameter CLK_HZ       = 50_000_000,
+    parameter PAYLOAD_BITS = 8,
+    parameter STOP_BITS    = 1
+)(
 input  wire       clk          , // Top level system clock input.
 input  wire       resetn       , // Asynchronous active low reset.
 input  wire       uart_rxd     , // UART Recieve pin.
@@ -16,27 +21,15 @@ output wire       uart_rx_valid, // Valid data recieved and available.
 output reg  [PAYLOAD_BITS-1:0] uart_rx_data   // The recieved data.
 );

-// ---------------------------------------------------------------------------
+// ---------------------------------------------------------------------------
 // External parameters.
-//
-
 //
-// Input bit rate of the UART line.
-parameter   BIT_RATE        = 9600; // bits / sec
-localparam  BIT_P           = 1_000_000_000 * 1/BIT_RATE; // nanoseconds

 //
-// Clock frequency in hertz.
-parameter   CLK_HZ          =    50_000_000;
-localparam  CLK_P           = 1_000_000_000 * 1/CLK_HZ; // nanoseconds
-
-//
-// Number of data bits recieved per UART packet.
-parameter   PAYLOAD_BITS    = 8;
-
-//
-// Number of stop bits indicating the end of a packet.
-parameter   STOP_BITS       = 1;
+// Derived from the BIT_RATE / CLK_HZ parameters declared in the SV-style
+// module header above.
+localparam  BIT_P           = 1_000_000_000 * 1/BIT_RATE; // nanoseconds
+localparam  CLK_P           = 1_000_000_000 * 1/CLK_HZ;   // nanoseconds

 // --------------------------------------------------------------------------
 // Internal parameters.
diff --git a/rtl/uart_tx.v b/rtl/uart_tx.v
index 89906d6..115660e 100644
--- a/rtl/uart_tx.v
+++ b/rtl/uart_tx.v
@@ -7,7 +7,12 @@
 // - UART transmitter module.
 //

-module uart_tx(
+module uart_tx #(
+    parameter BIT_RATE     = 9600,
+    parameter CLK_HZ       = 50_000_000,
+    parameter PAYLOAD_BITS = 8,
+    parameter STOP_BITS    = 1
+)(
 input  wire         clk         , // Top level system clock input.
 input  wire         resetn      , // Asynchronous active low reset.
 output wire         uart_txd    , // UART transmit pin.
@@ -16,27 +21,15 @@ input  wire         uart_tx_en  , // Send the data on uart_tx_data
 input  wire [PAYLOAD_BITS-1:0]   uart_tx_data  // The data to be sent
 );

-// ---------------------------------------------------------------------------
+// ---------------------------------------------------------------------------
 // External parameters.
-//
-
 //
-// Input bit rate of the UART line.
-parameter   BIT_RATE        = 9600; // bits / sec
-localparam  BIT_P           = 1_000_000_000 * 1/BIT_RATE; // nanoseconds

 //
-// Clock frequency in hertz.
-parameter   CLK_HZ          =    50_000_000;
-localparam  CLK_P           = 1_000_000_000 * 1/CLK_HZ; // nanoseconds
-
-//
-// Number of data bits recieved per UART packet.
-parameter   PAYLOAD_BITS    = 8;
-
-//
-// Number of stop bits indicating the end of a packet.
-parameter   STOP_BITS       = 1;
+// Derived from the BIT_RATE / CLK_HZ parameters declared in the SV-style
+// module header above.
+localparam  BIT_P           = 1_000_000_000 * 1/BIT_RATE; // nanoseconds
+localparam  CLK_P           = 1_000_000_000 * 1/CLK_HZ;   // nanoseconds

 // ---------------------------------------------------------------------------
 // Internal parameters.
